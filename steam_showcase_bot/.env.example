TELEGRAM_BOT_TOKEN=your_bot_token_here
LOG_LEVEL=INFO
LOG_FILE=steam_showcase_bot.log
LOG_TO_FILE=1
SAVE_UPLOADS=1

# Лимиты
MAX_FILE_SIZE_MB=20
MAX_ARCHIVE_SEND_MB=50
RATE_LIMIT_SECONDS=30
MAX_CONCURRENT_TASKS=3

# Сетевые настройки
TELEGRAM_CLIENT_TIMEOUT=300
TELEGRAM_CLIENT_CONNECT_LIMIT=0
ZIP_SEND_RETRIES=3
ZIP_SEND_TIMEOUT=300

# Graceful shutdown
SHUTDOWN_TASK_WAIT_TIMEOUT=30
FFMPEG_TERMINATE_TIMEOUT=5

# Healthcheck heartbeat
HEARTBEAT_FILE=/tmp/steam_showcase_bot.heartbeat
HEARTBEAT_INTERVAL_SECONDS=5
HEALTHCHECK_MAX_STALENESS_SECONDS=20
